<?xml version="1.0" ?>
<robot name="simple_box">

  <link name="base_link">

    <visual>

      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>

        <box size="5 0.5 0.1"/>
      </geometry>

      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>


    <collision>

      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
 
        <box size="5 0.5 0.1"/>
      </geometry>
 
    </collision>

 
    <inertial>
 
        <origin xyz="0 0 0" rpy="0 0 0" />
 
        <mass value="1" />
 
        <inertia ixx="0.000034533333" 
            ixy="0"  ixz="0"
            iyx="0"  iyy="0.000034533333" 
            iyz="0"
            izx="0"  izy="0"  izz="0.0000648" />
    </inertial>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2.6 0.5 1.0"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2.6 0.5 1.0"/>
      </geometry>
    </collision>

    <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.000034533333" 
            ixy="0"  ixz="0"
            iyx="0"  iyy="0.000034533333" 
            iyz="0"
            izx="0"  izy="0"  izz="0.0000648" />
    </inertial>
  </link>

  <joint name="joint1" type="fixed">
    <origin xyz="1.35 0 0.5" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link1"/>
  </joint>

 
  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2.6 0.5 1.0"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2.6 0.5 1.0"/>
      </geometry>
    </collision>

    <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1" />
        <inertia ixx="0.000034533333" 
            ixy="0"  ixz="0"
            iyx="0"  iyy="0.000034533333" 
            iyz="0"
            izx="0"  izy="0"  izz="0.0000648" />
    </inertial>

  </link>
  
  <joint name="joint2" type="fixed">
    <origin xyz="-1.35 0 0.5" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link2"/>
  </joint>

</robot>