<?xml version="1.0" ?>
<robot name="conveyor_belt">
  
  <!-- Main conveyor belt (5m long) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="5.0 0.5 0.05"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="5.0 0.5 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="100.0"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0"/>
    </inertial>
  </link>

  <!-- START SENSOR - ray origin point -->
  <link name="start_sensor_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.1"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="start_sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="start_sensor_link"/>
    <origin xyz="-2.3 -0.3 0.08" rpy="0 0 0"/>
  </joint>

  <!-- START SENSOR TARGET - ray end point -->
  <link name="start_sensor_target_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.1"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="start_sensor_target_joint" type="fixed">
    <parent link="base_link"/>
    <child link="start_sensor_target_link"/>
    <origin xyz="-2.3 0.3 0.08" rpy="0 0 0"/>
  </joint>

  <!-- END SENSOR - ray origin point -->
  <link name="end_sensor_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="end_sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="end_sensor_link"/>
    <origin xyz="2.3 -0.3 0.08" rpy="0 0 0"/>
  </joint>

  <!-- END SENSOR TARGET - ray end point -->
  <link name="end_sensor_target_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="end_sensor_target_joint" type="fixed">
    <parent link="base_link"/>
    <child link="end_sensor_target_link"/>
    <origin xyz="2.3 0.3 0.08" rpy="0 0 0"/>
  </joint>

  <!-- Support legs -->
  <link name="leg_1">
    <visual><geometry><cylinder length="0.4" radius="0.03"/></geometry>
    <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder length="0.4" radius="0.03"/></geometry></collision>
    <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="leg_1_joint" type="fixed">
    <parent link="base_link"/><child link="leg_1"/>
    <origin xyz="-2.0 0.2 -0.225" rpy="0 0 0"/>
  </joint>

  <link name="leg_2">
    <visual><geometry><cylinder length="0.4" radius="0.03"/></geometry>
    <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder length="0.4" radius="0.03"/></geometry></collision>
    <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="leg_2_joint" type="fixed">
    <parent link="base_link"/><child link="leg_2"/>
    <origin xyz="-2.0 -0.2 -0.225" rpy="0 0 0"/>
  </joint>

  <link name="leg_3">
    <visual><geometry><cylinder length="0.4" radius="0.03"/></geometry>
    <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder length="0.4" radius="0.03"/></geometry></collision>
    <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="leg_3_joint" type="fixed">
    <parent link="base_link"/><child link="leg_3"/>
    <origin xyz="2.0 0.2 -0.225" rpy="0 0 0"/>
  </joint>

  <link name="leg_4">
    <visual><geometry><cylinder length="0.4" radius="0.03"/></geometry>
    <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder length="0.4" radius="0.03"/></geometry></collision>
    <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="leg_4_joint" type="fixed">
    <parent link="base_link"/><child link="leg_4"/>
    <origin xyz="2.0 -0.2 -0.225" rpy="0 0 0"/>
  </joint>

</robot>
